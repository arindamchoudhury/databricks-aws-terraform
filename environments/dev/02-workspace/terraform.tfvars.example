region                = "us-east-1"
prefix                = "dbx-dev"
state_bucket          = "myorg-databricks-tf-state"   # from: terraform -chdir=../../../bootstrap output state_bucket_name
databricks_account_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
databricks_client_id  = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# databricks_client_secret — set via env: $env:TF_VAR_databricks_client_secret = "..."
workspace_name        = "dev"
