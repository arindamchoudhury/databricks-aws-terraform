# Template for per-environment secrets. COMMITTED (safe — no real values).
#
# Setup: copy this file to live/<env>/secrets.hcl and fill in the real
# Databricks service-principal credentials for that environment. The real
# secrets.hcl files are gitignored.
#
#   cp live/secrets.hcl.example live/dev/secrets.hcl
#   cp live/secrets.hcl.example live/prod/secrets.hcl
#
locals {
  databricks_client_id     = "<databricks-service-principal-client-id>"
  databricks_client_secret = "<databricks-service-principal-client-secret>"
}
